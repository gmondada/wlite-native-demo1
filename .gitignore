# Per-target build config generated by `idf.py set-target` / menuconfig.
# The source of truth is sdkconfig.defaults plus per-target overlays.
sdkconfig
sdkconfig.old

# Managed components — fetched by the IDF component manager from
# components.espressif.com on `idf.py set-target` / `reconfigure`.
# The dependency manifests (main/idf_component.yml,
# components/*/idf_component.yml) plus dependencies.lock are the
# source of truth. Tracking the resolved tree was painful with
# multi-target builds because the per-target dep closures differ.
managed_components/
